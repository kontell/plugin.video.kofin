        <setting id="deviceId" type="string">
          <level>4</level>
          <default></default>
          <constraints><allowempty>true</allowempty></constraints>
          <control type="edit" format="string"/>
        </setting>

        <setting id="serverAddress" type="string" label="30052" help="30053">
          <level>0</level>
          <default></default>
          <constraints><allowempty>true</allowempty></constraints>
