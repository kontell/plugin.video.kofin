          <level>4</level>
          <default>false</default>
          <control type="toggle"/>
        </setting>
        <setting id="serverId" type="string">
          <level>4</level>
          <default></default>
          <constraints><allowempty>true</allowempty></constraints>
          <control type="edit" format="string"/>
