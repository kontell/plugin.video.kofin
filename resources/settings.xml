            </dependency>
          </dependencies>
          <control type="button" format="action">
            <data>RunPlugin(plugin://plugin.video.kofin/?mode=login)</data>
            <close>true</close>
          </control>
        </setting>
        <setting id="serverName" type="string" label="30056" help="30057">
