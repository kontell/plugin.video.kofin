          <dependencies>
            <dependency type="visible">
              <condition operator="is" setting="forceDirectPlay">false</condition>
            </dependency>
          </dependencies>
          <control type="toggle"/>
        </setting>
        <!-- The list[string] settings below carry no forceDirectPlay visibility
             dependency: on Omega, a <dependencies> block attached to a
             list[string] setting silently unregisters the setting it
             references, so forceDirectPlay vanished from the manager and
             every lookup of it warned (Kodi settings-manager bug, verified
             empirically on 21.3). -->
        <setting id="directPlayVideoCodecs" type="list[string]" label="30108" help="30109">
          <level>0</level>
          <default>h264,h264_10bit,hevc,hevc_rext,av1,mpeg2video,vp9,vc1</default>
          <constraints>
            <options>
              <option label="30150">h264</option>
              <option label="30151">h264_10bit</option>
              <option label="30152">hevc</option>
              <option label="30153">hevc_rext</option>
              <option label="30154">av1</option>
              <option label="30155">mpeg2video</option>
              <option label="30156">vp9</option>
              <option label="30157">vc1</option>
            </options>
            <delimiter>,</delimiter>
          </constraints>
          <control type="list" format="string">
            <multiselect>true</multiselect>
            <hidevalue>true</hidevalue>
          </control>
        </setting>
        <setting id="directPlayAudioCodecs" type="list[string]" label="30110" help="30111">
          <level>0</level>
          <default>aac,mp2,mp3,ac3,eac3,opus,flac,dts</default>
